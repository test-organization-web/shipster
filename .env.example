# Copy to `.env` and adjust. Shipster reads these via `shipster.platform.settings.get_global_settings`.
# The app does not load `.env` by itself — export variables, use Docker `environment:`, or a shell
# helper (e.g. `set -a && source .env && set +a` before `uvicorn`).
# Alternate names (where noted) are accepted for convenience — first non-empty wins.

# --- Database (SQLAlchemy URL) ---
# Default in code: in-memory SQLite. For a local file: sqlite+pysqlite:///./shipster.db
# Docker Compose (``postgres`` service): postgresql+psycopg://shipster:shipster@localhost:5432/shipster
# SHIPSTER_DATABASE_URL takes precedence over DATABASE_URL.
SHIPSTER_DATABASE_URL=
# DATABASE_URL=

# --- Redis ---
# Docker Compose sets: redis://redis:6379/0
# SHIPSTER_REDIS_URL takes precedence over REDIS_URL.
SHIPSTER_REDIS_URL=redis://localhost:6379/0
# REDIS_URL=

# --- Messaging (e.g. org invitation consumer) ---
# SHIPSTER_MESSAGING_BACKEND takes precedence over MESSAGING_BACKEND.
SHIPSTER_MESSAGING_BACKEND=redis
# MESSAGING_BACKEND=

# RabbitMQ (optional; used when messaging is configured to use it)
# Docker Compose uses: amqp://guest:guest@rabbitmq:5672/
# SHIPSTER_RABBITMQ_URL takes precedence over RABBITMQ_URL.
SHIPSTER_RABBITMQ_URL=
# RABBITMQ_URL=

# --- Background jobs / worker runtime ---
# Set to 0, false, or no to keep the current process HTTP-only.
# Docker Compose sets this to false for `web` and true for `worker`.
SHIPSTER_BACKGROUND_JOBS_ENABLED=

# --- JWT (access tokens) ---
# Use a long random secret in production.
SHIPSTER_JWT_SECRET=dev-insecure-secret-change-me-32b

# --- Debug: request latency (JWT verify, use-case DB, route, broker publish) ---
# Set to 1, true, or yes to enable DEBUG logs on logger shipster.debug.request_timing.
SHIPSTER_DEBUG_REQUEST_TIMING=

# --- HTTP audit logging ---
# Set to 1, true, or yes to enable metadata-only HTTP audit logs.
SHIPSTER_HTTP_AUDIT=
# Set to 1, true, or yes to include redacted request/response body previews too.
# Keep this disabled in production unless you have a short-lived debugging need.
SHIPSTER_HTTP_AUDIT_LOG_BODIES=

# --- Organization invitation delivery ---
# Optional URL template for invitation emails. You may use {token} and {organization_id}.
SHIPSTER_ORG_INVITATION_ACCEPT_URL_TEMPLATE=

