[importlinter]
root_packages =
    apps
    shipster

[importlinter:contract:users-domain-no-shipster]
name = Users domain does not depend on platform
type = forbidden
source_modules =
    apps.users.domain
forbidden_modules =
    shipster

[importlinter:contract:users-application-no-shipster]
name = Users application does not depend on platform
type = forbidden
source_modules =
    apps.users.application
forbidden_modules =
    shipster

[importlinter:contract:users-infrastructure-no-shipster]
name = Users infrastructure does not depend on platform
type = forbidden
source_modules =
    apps.users.infrastructure
forbidden_modules =
    shipster

[importlinter:contract:users-domain-isolation]
name = Users domain is independent of outer layers
type = forbidden
source_modules =
    apps.users.domain
forbidden_modules =
    apps.users.application
    apps.users.infrastructure
    apps.users.interfaces

[importlinter:contract:users-application-no-infra]
name = Users application does not depend on infrastructure or interfaces
type = forbidden
source_modules =
    apps.users.application
forbidden_modules =
    apps.users.infrastructure
    apps.users.interfaces

